            ]
        ]
    },
    {
        "id": "ea2d29eb83cca827",
        "type": "function",
        "z": "f2cfb835707f7a96",
        "name": "function 3",
        "func": "\nconst data = msg.payload || {};\n\nconst doc = {\n    cep: data.cep || null,\n    street: data.street || data.logradouro || null,\n    neighborhood: data.neighborhood || data.bairro || null,\n    city: data.city || data.localidade || null,\n    state: data.state || data.uf || null,\n    timestamp: new Date()\n};\n\nmsg = { payload: doc };\n\nreturn msg;\n",
