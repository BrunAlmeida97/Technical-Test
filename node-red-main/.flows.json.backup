    {
        "id": "f90b043ae7c1d78d",
        "type": "template",
        "z": "f2cfb835707f7a96",
        "name": "",
        "field": "payload",
        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "<style>\n  .navbar {\n    background: #222;\n    padding: 12px 20px;\n    display: flex;\n    gap: 20px;\n    align-items: center;\n  }\n  .navbar a {\n    color: #eee;\n    text-decoration: none;\n    font-weight: 600;\n  }\n  .navbar a:hover {\n    color: #ffd54f;\n  }\n</style>\n\n<style>\n.card {\n    background-color: #e8f4ff;\n    padding: 20px;\n    border-radius: 10px;\n    max-width: 400px;\n    margin: 20px auto;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n    font-family: Arial;\n}\n\n.card-error {\n    background-color: #fafafa;\n    padding: 20px;\n    border-radius: 10px;\n    max-width: 400px;\n    margin: 20px auto;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.1);\n    font-family: Arial;\n}\n\n.button {\n  background: #4a90e2;\n  color: white;\n  padding: 12px 25px;\n  border: none;\n  border-radius: 8px;\n  font-size: 16px;\n  cursor: pointer;\n  transition: 0.3s;\n}\n\n.button:hover {\n  background: #1c6dc6;\n  transform: scale(1.05); \n}\n</style>\n\n\n<style>\n body {\n    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n    background: #f3f6fb;\n    margin: 0;\n    padding: 20px;\n  }\n</style>\n\n<div class=\"navbar\">\n  <a href=\"/corretoras\">Corretoras</a>\n  <a href=\"/cep\">Buscar CEP</a>\n</div>\n\n<h2>Resultado</h2>\n\n{{#hasResult}}\n<div class=\"card\">\n    <p><b>CEP:</b> {{payload.cep}}</p>\n    <p><b>Rua:</b> {{payload.street}}</p>\n    <p><b>Bairro:</b> {{payload.neighborhood}}</p>\n    <p><b>Cidade:</b> {{payload.city}} / {{payload.state}}</p>\n</div>\n{{/hasResult}}\n\n{{^hasResult}}\n<div class=\"card-error\">\n    <p style=\"color:red; font-weight: bold;\">{{errorMessage}}</p>\n</div>\n{{/hasResult}}\n\n<form action=\"/cep\" method=\"GET\">\n     <button class=\"button\">Nova busca</button>\n</form>\n\n\n",
        "output": "str",
        "x": 940,
        "y": 320,
