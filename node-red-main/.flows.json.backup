    {
        "id": "c4efc1e553681d29",
        "type": "function",
        "z": "f2cfb835707f7a96",
        "name": "function 2",
        "func": "if (!msg.payload || msg.payload.error || msg.statusCode !== 200) {\n    msg.hasResult = false;\n    msg.errorMessage = \"CEP não encontrado. Verifique e tente novamente.\";\n    return msg;\n}\n\nmsg.hasResult = true;\nreturn msg;\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 760,
        "y": 320,
