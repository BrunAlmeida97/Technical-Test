    {
        "id": "6851dbe360ce9554",
        "type": "template",
        "z": "f2cfb835707f7a96",
        "name": "",
        "field": "payload",
        "fieldType": "msg",
        "format": "handlebars",
        "syntax": "mustache",
        "template": "<style>\n  .navbar {\n    background: #222;\n    padding: 12px 20px;\n    display: flex;\n    gap: 20px;\n    align-items: center;\n  }\n  .navbar a {\n    color: #eee;\n    text-decoration: none;\n    font-weight: 600;\n  }\n  .navbar a:hover {\n    color: #ffd54f;\n  }\n</style>\n\n<style>\n body {\n    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;\n    background: #f3f6fb;\n    margin: 0;\n    padding: 20px;\n  }\n\n  .search-container{\n    display: grid;\n    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n    gap: 20px;\n    margin-top: 20px;\n  }\n\n.search-box {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 10px;\n  margin: 20px auto;\n  padding: 20px;\n  width: 100%;\n}\n\n.search-box input {\n  width: 350px; \n  padding: 12px 15px;\n  font-size: 16px;\n  border: 2px solid #4a90e2;\n  border-radius: 8px;\n  outline: none;\n  transition: 0.3s;\n}\n\n.search-box input:focus {\n  border-color: #1c6dc6;      \n  box-shadow: 0 0 8px rgba(30, 100, 200, 0.3);\n}\n\n.search-box button {\n  background: #4a90e2;\n  color: white;\n  padding: 12px 25px;\n  border: none;\n  border-radius: 8px;\n  font-size: 16px;\n  cursor: pointer;\n  transition: 0.3s;\n}\n\n.search-box button:hover {\n  background: #1c6dc6;\n  transform: scale(1.05); \n}\n\n \n</style>\n\n<div class=\"navbar\">\n  <a href=\"/corretoras\">Corretoras</a>\n  <a href=\"/cep\">Buscar CEP</a>\n</div>\n\n\n<h2>Busca CEP</h2>\n<div class=\"search-container\">\n  <div class=\"search-card\"> \n<form method=\"GET\" action=\"/cep-search\">\n<div class=\"search-box\">\n  <input name=\"zipcode\" placeholder=\"Enter CEP\">\n  <button id=\"search-btn\">Search</button>\n</div>\n  </div>\n</div>\n</form>\n",
        "output": "str",
        "x": 520,
