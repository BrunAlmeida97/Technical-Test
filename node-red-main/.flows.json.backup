    {
        "id": "409d960e746c0457",
        "type": "function",
        "z": "f2cfb835707f7a96",
        "name": "function 1",
        "func": "msg.cep = msg.req.query.zipcode ? msg.req.query.zipcode :msg.req.params.cep;\nmsg.url = `https://brasilapi.com.br/api/cep/v2/${msg.cep}`;\nreturn msg;\n",
